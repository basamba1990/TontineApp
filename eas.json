{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.0.0"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.0.0",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "node": "20.0.0",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json"
      }
    }
  }
}
