{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"       // Build APK pour tester rapidement
      }
    },
    "production": {
      "distribution": "store",   // Google Play / App Store
      "android": {
        "buildType": "app-bundle" // Génère AAB recommandé par Google Play
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json"
      }
    }
  }
}
